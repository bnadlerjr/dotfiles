#!/bin/sh

# Create a Git worktree for a branch inside a bare repo layout.
#
# Creates a new worktree directory as a sibling inside the bare repo root.
# If the branch exists locally or on the remote, it is checked out. Otherwise,
# a new branch is created from the given starting point (default: HEAD).
#
# If a scripts/setup-worktree file exists in the new worktree, it is
# executed automatically.
#
# When inside tmux, opens the new worktree in a new window named after
# the branch. When outside tmux, prints the path to stdout (for use
# with cd wrappers).
#
# USAGE:
#   git wt-add <branch-name> [base-ref]
#
# EXAMPLES:
#   git wt-add feature/my-branch
#   git wt-add feature/my-branch main
#

# -e: Exit immediately on error
# -u: Treat unset variables as errors
set -eu

if [ $# -lt 1 ]; then
    echo "Usage: git wt-add <branch-name> [base-ref]" >&2
    exit 1
fi

branch="$1"
base="${2:-HEAD}"

# Turn "feature/my-branch" into "feature-my-branch" for the directory name
dir_name=$(echo "$branch" | tr '/' '-')

# Find the bare repo root
root=$(git rev-parse --git-common-dir 2>/dev/null)
if [ -z "$root" ] || [ "$root" = ".git" ]; then
    echo "error: not inside a bare repo or worktree" >&2
    exit 1
fi

worktree_path="$root/$dir_name"

if git show-ref --verify --quiet "refs/heads/$branch" 2>/dev/null; then
    echo "Checking out existing local branch '$branch'..." >&2
    git worktree add "$worktree_path" "$branch" >&2
elif git show-ref --verify --quiet "refs/remotes/origin/$branch" 2>/dev/null; then
    echo "Checking out remote branch '$branch'..." >&2
    git worktree add "$worktree_path" "$branch" >&2
else
    echo "Creating new branch '$branch' from $base..." >&2
    git worktree add -b "$branch" "$worktree_path" "$base" >&2
fi

if [ -n "${TMUX:-}" ]; then
    if [ -x "$worktree_path/scripts/setup-worktree" ]; then
        tmux new-window -n "$branch" -c "$worktree_path" \
            "./scripts/setup-worktree; exec ${SHELL:-sh}"
    else
        tmux new-window -n "$branch" -c "$worktree_path"
    fi
else
    # No separate window; run setup inline before printing the path
    if [ -x "$worktree_path/scripts/setup-worktree" ]; then
        echo "Running setup-worktree..." >&2
        (cd "$worktree_path" && ./scripts/setup-worktree) >&2
    fi
    echo "$worktree_path"
fi
