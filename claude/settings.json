{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Read(~/.claude/**)",
      "Read(~/dotfiles/claude/**)",
      "Read(~/Dropbox/vimwiki/claude-artifacts/**)",
      "Edit(~/Dropbox/vimwiki/claude-artifacts/**)",
      "Write(~/Dropbox/vimwiki/claude-artifacts/**)",
      "Bash(gh pr view *)",
      "Bash(gh pr list *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr checks *)",
      "Bash(gh pr status)",
      "Bash(gh issue view *)",
      "Bash(gh issue list *)",
      "Bash(gh issue status)",
      "Bash(gh repo view *)",
      "Bash(gh repo list *)",
      "Bash(gh search *)",
      "Bash(gh status)",
      "Bash(jira me)",
      "Bash(jira issue view *)",
      "Bash(jira issue list *)",
      "Bash(jira issue transitions *)",
      "Bash(jira sprint list *)",
      "Bash(jira epic list *)",
      "Bash(jira project list *)",
      "Bash(jira board list *)",
      "Bash(jira open *)"
    ]
  },
  "model": "opus[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "uv run ~/dotfiles/claude/hooks/capture-event.py"
          },
          {
            "type": "command",
            "command": "uv run ~/dotfiles/claude/hooks/log-event-jsonl.py"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "uv run ~/dotfiles/claude/hooks/tdd-gate.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "uv run ~/dotfiles/claude/hooks/lint.py"
          },
          {
            "type": "command",
            "command": "uv run ~/dotfiles/claude/hooks/code-simplifier-reminder.py"
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "uv run ~/dotfiles/claude/hooks/capture-event.py"
          },
          {
            "type": "command",
            "command": "uv run ~/dotfiles/claude/hooks/log-event-jsonl.py"
          },
          {
            "type": "command",
            "command": "uv run ~/dotfiles/claude/hooks/notification.py"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run ~/dotfiles/claude/hooks/capture-event.py"
          },
          {
            "type": "command",
            "command": "uv run ~/dotfiles/claude/hooks/log-event-jsonl.py"
          },
          {
            "type": "command",
            "command": "uv run ~/dotfiles/claude/hooks/notification.py"
          },
          {
            "type": "command",
            "command": "uv run ~/dotfiles/claude/hooks/plan-mode-context.py"
          },
          {
            "type": "command",
            "command": "uv run ~/dotfiles/claude/hooks/save-plan-artifact.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run ~/dotfiles/claude/hooks/capture-event.py"
          },
          {
            "type": "command",
            "command": "uv run ~/dotfiles/claude/hooks/log-event-jsonl.py"
          },
          {
            "type": "command",
            "command": "uv run ~/dotfiles/claude/hooks/notification.py"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run ~/dotfiles/claude/hooks/capture-event.py"
          },
          {
            "type": "command",
            "command": "uv run ~/dotfiles/claude/hooks/log-event-jsonl.py"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run ~/dotfiles/claude/hooks/capture-event.py"
          },
          {
            "type": "command",
            "command": "uv run ~/dotfiles/claude/hooks/log-event-jsonl.py"
          },
          {
            "type": "command",
            "command": "uv run ~/dotfiles/claude/hooks/notification.py"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run ~/dotfiles/claude/hooks/capture-event.py"
          },
          {
            "type": "command",
            "command": "uv run ~/dotfiles/claude/hooks/log-event-jsonl.py"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run ~/dotfiles/claude/hooks/capture-event.py"
          },
          {
            "type": "command",
            "command": "uv run ~/dotfiles/claude/hooks/log-event-jsonl.py"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run ~/dotfiles/claude/hooks/capture-event.py"
          },
          {
            "type": "command",
            "command": "uv run ~/dotfiles/claude/hooks/log-event-jsonl.py"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run ~/dotfiles/claude/hooks/capture-event.py"
          },
          {
            "type": "command",
            "command": "uv run ~/dotfiles/claude/hooks/log-event-jsonl.py"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run ~/dotfiles/claude/hooks/capture-event.py"
          },
          {
            "type": "command",
            "command": "uv run ~/dotfiles/claude/hooks/log-event-jsonl.py"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run ~/dotfiles/claude/hooks/capture-event.py"
          },
          {
            "type": "command",
            "command": "uv run ~/dotfiles/claude/hooks/log-event-jsonl.py"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "npx -y ccstatusline@latest",
    "padding": 0
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "voiceEnabled": false,
  "feedbackSurveyState": {
    "lastShownTime": 1754088826871
  },
  "skipAutoPermissionPrompt": true
}
