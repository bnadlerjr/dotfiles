{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(MIX_ENV=test mix compile *)",
      "Bash(MIX_ENV=test mix credo *)",
      "Bash(MIX_ENV=test mix dialyzer *)",
      "Bash(MIX_ENV=test mix ecto.create *)",
      "Bash(MIX_ENV=test mix ecto.drop *)",
      "Bash(MIX_ENV=test mix ecto.migrate *)",
      "Bash(MIX_ENV=test mix ecto.reset *)",
      "Bash(MIX_ENV=test mix ecto.rollback *)",
      "Bash(MIX_ENV=test mix format *)",
      "Bash(MIX_ENV=test mix help *)",
      "Bash(MIX_ENV=test mix hex.outdated *)",
      "Bash(MIX_ENV=test mix test *)",
      "Bash(cat *)",
      "Bash(docker logs *)",
      "Bash(docker ps *)",
      "Bash(echo *)",
      "Bash(find *)",
      "Bash(gh issue list *)",
      "Bash(gh issue status *)",
      "Bash(gh issue view *)",
      "Bash(gh pr checks *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr list *)",
      "Bash(gh pr status *)",
      "Bash(gh pr view *)",
      "Bash(gh repo list *)",
      "Bash(gh repo view *)",
      "Bash(gh search *)",
      "Bash(gh status *)",
      "Bash(git machete completion *)",
      "Bash(git machete diff *)",
      "Bash(git machete file *)",
      "Bash(git machete format *)",
      "Bash(git machete help *)",
      "Bash(git machete hooks *)",
      "Bash(git machete is-managed *)",
      "Bash(git machete list *)",
      "Bash(git machete log *)",
      "Bash(git machete show *)",
      "Bash(git machete status *)",
      "Bash(git machete version *)",
      "Bash(git rev-parse *)",
      "Bash(git show *)",
      "Bash(grep *)",
      "Bash(jira board list *)",
      "Bash(jira epic list *)",
      "Bash(jira issue link list *)",
      "Bash(jira issue list *)",
      "Bash(jira issue transitions *)",
      "Bash(jira issue view *)",
      "Bash(jira issue *)",
      "Bash(jira me *)",
      "Bash(jira open *)",
      "Bash(jira project list *)",
      "Bash(jira sprint list *)",
      "Bash(ls *)",
      "Bash(mix compile *)",
      "Bash(mix credo *)",
      "Bash(mix dialyzer *)",
      "Bash(mix ecto.create *)",
      "Bash(mix ecto.drop *)",
      "Bash(mix ecto.gen.migration *)",
      "Bash(mix ecto.migrate *)",
      "Bash(mix ecto.reset *)",
      "Bash(mix ecto.rollback *)",
      "Bash(mix format *)",
      "Bash(mix help *)",
      "Bash(mix hex.info *)",
      "Bash(mix hex.outdated *)",
      "Bash(mix lint *)",
      "Bash(mix sobelow *)",
      "Bash(mix test *)",
      "Bash(mkdir *)",
      "Bash(rg *)",
      "Bash(sloc *)",
      "Bash(sort *)",
      "Bash(terraform plan *)",
      "Bash(terraform validate *)",
      "Bash(wc *)",
      "Edit(/tmp/**)",
      "Edit(~/Dropbox/vimwiki/claude-artifacts/**)",
      "Read(/tmp/**)",
      "Read(~/.claude/**)",
      "Read(~/Dropbox/vimwiki/claude-artifacts/**)",
      "Read(~/dotfiles/claude/**)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:docs.datadoghq.com)",
      "WebFetch(domain:gist.github.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:hex.pm)",
      "WebFetch(domain:hexdocs.pm)",
      "Write(/tmp/**)",
      "Write(~/Dropbox/vimwiki/claude-artifacts/**)"
    ]
  },
  "model": "opus[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "uv run ~/dotfiles/claude/hooks/capture-event.py"
          },
          {
            "type": "command",
            "command": "uv run ~/dotfiles/claude/hooks/log-event-jsonl.py"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "uv run ~/dotfiles/claude/hooks/tdd-gate.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "uv run ~/dotfiles/claude/hooks/lint.py"
          },
          {
            "type": "command",
            "command": "uv run ~/dotfiles/claude/hooks/code-simplifier-reminder.py"
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "uv run ~/dotfiles/claude/hooks/capture-event.py"
          },
          {
            "type": "command",
            "command": "uv run ~/dotfiles/claude/hooks/log-event-jsonl.py"
          },
          {
            "type": "command",
            "command": "uv run ~/dotfiles/claude/hooks/notification.py"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run ~/dotfiles/claude/hooks/capture-event.py"
          },
          {
            "type": "command",
            "command": "uv run ~/dotfiles/claude/hooks/log-event-jsonl.py"
          },
          {
            "type": "command",
            "command": "uv run ~/dotfiles/claude/hooks/notification.py"
          },
          {
            "type": "command",
            "command": "uv run ~/dotfiles/claude/hooks/plan-mode-context.py"
          },
          {
            "type": "command",
            "command": "uv run ~/dotfiles/claude/hooks/save-plan-artifact.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run ~/dotfiles/claude/hooks/capture-event.py"
          },
          {
            "type": "command",
            "command": "uv run ~/dotfiles/claude/hooks/log-event-jsonl.py"
          },
          {
            "type": "command",
            "command": "uv run ~/dotfiles/claude/hooks/notification.py"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run ~/dotfiles/claude/hooks/capture-event.py"
          },
          {
            "type": "command",
            "command": "uv run ~/dotfiles/claude/hooks/log-event-jsonl.py"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run ~/dotfiles/claude/hooks/capture-event.py"
          },
          {
            "type": "command",
            "command": "uv run ~/dotfiles/claude/hooks/log-event-jsonl.py"
          },
          {
            "type": "command",
            "command": "uv run ~/dotfiles/claude/hooks/notification.py"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run ~/dotfiles/claude/hooks/capture-event.py"
          },
          {
            "type": "command",
            "command": "uv run ~/dotfiles/claude/hooks/log-event-jsonl.py"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run ~/dotfiles/claude/hooks/capture-event.py"
          },
          {
            "type": "command",
            "command": "uv run ~/dotfiles/claude/hooks/log-event-jsonl.py"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run ~/dotfiles/claude/hooks/capture-event.py"
          },
          {
            "type": "command",
            "command": "uv run ~/dotfiles/claude/hooks/log-event-jsonl.py"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run ~/dotfiles/claude/hooks/capture-event.py"
          },
          {
            "type": "command",
            "command": "uv run ~/dotfiles/claude/hooks/log-event-jsonl.py"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run ~/dotfiles/claude/hooks/capture-event.py"
          },
          {
            "type": "command",
            "command": "uv run ~/dotfiles/claude/hooks/log-event-jsonl.py"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run ~/dotfiles/claude/hooks/capture-event.py"
          },
          {
            "type": "command",
            "command": "uv run ~/dotfiles/claude/hooks/log-event-jsonl.py"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "npx -y ccstatusline@latest",
    "padding": 0
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "voiceEnabled": false,
  "feedbackSurveyState": {
    "lastShownTime": 1754088826871
  },
  "skipAutoPermissionPrompt": true
}
