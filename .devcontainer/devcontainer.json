{
  "name": "Dotfiles Agent Sandbox",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "TZ": "${localEnv:TZ:America/New_York}",
      "CLAUDE_CODE_VERSION": "latest",
      "GIT_DELTA_VERSION": "0.18.2"
    }
  },
  "runArgs": [
    "--cap-add=NET_ADMIN",
    "--cap-add=NET_RAW",
    "--name=dotfiles",
    "--hostname=dotfiles"
  ],
  "remoteUser": "dotfiles",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=delegated",
  "workspaceFolder": "/workspace",
  "mounts": [
    "source=dotfiles-claude,target=/home/dotfiles/.claude,type=volume",
    "source=dotfiles-history,target=/commandhistory,type=volume",
    "source=${localEnv:HOME}/.gitconfig.local,target=/home/dotfiles/.gitconfig.local,type=bind,readonly",
    "source=${localEnv:HOME}/.claude/events-log,target=/home/dotfiles/.claude/events-log,type=bind"
  ],
  "initializeCommand": "mkdir -p ${localEnv:HOME}/.claude/events-log",
  "containerEnv": {
    "CLAUDE_CONFIG_DIR": "/home/dotfiles/.claude",
    "DEVCONTAINER": "true",
    "EDITOR": "nvim"
  },
  "postCreateCommand": "/usr/local/bin/post-create.sh",
  "postStartCommand": "sudo /usr/local/bin/init-firewall.sh",
  "postAttachCommand": "/usr/local/bin/print-welcome.sh",
  "waitFor": "postStartCommand"
}
